            "data": {
              "type": "tm.Process",
              "name": "Auth Service",
              "description": "Logical sub-component of the Express API responsible for JWT issuance and verification. Hardcoded JWT secret is a key weakness.",
              "outOfScope": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "privilegeLevel": "",
              "threats": [
                {
                  "id": "threat-0003",
                  "number": 3,
                  "title": "Hardcoded JWT Secret",
                  "status": "Open",
                  "severity": "High",
                  "type": "Information disclosure",
                  "description": "The JWT signing secret is hardcoded as 'secret123' in server.js. Anyone with read access to the source code (e.g. a public repo, a leaked build artifact) can forge valid tokens for any user ID.",
                  "mitigation": "Load the secret from an environment variable (process.env.JWT_SECRET). Rotate the secret immediately if it has been exposed. Use a cryptographically random value of at least 256 bits.",
                  "modelType": "STRIDE",
                  "new": false,
                  "score": ""
                }
              ]
            }
