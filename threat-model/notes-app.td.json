            "id": "flow-login-req",
            "source": { "cell": "node-browser", "port": "browser-right" },
            "target": { "cell": "node-api",     "port": "api-left"      },
            "vertices": [{ "x": 265, "y": 240 }],
            "data": {
              "type": "tm.Flow",
              "name": "Login Request",
              "description": "POST /login — username and password sent in plaintext over HTTP",
              "outOfScope": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "isBidirectional": false,
              "isEncrypted": false,
              "isPublicNetwork": true,
              "protocol": "HTTP",
              "threats": [
                {
                  "id": "threat-0001",
                  "number": 1,
                  "title": "Brute Force on /login — No Rate Limiting",
                  "status": "Open",
                  "severity": "High",
                  "type": "Spoofing",
                  "description": "The /login endpoint has no rate limiting or account lockout. An attacker can make unlimited automated password guesses against any username, enabling credential brute-force attacks.",
                  "mitigation": "Apply express-rate-limit to /login (e.g. max 10 requests per 15 minutes per IP). Add progressive delay or account lockout after N consecutive failures. Consider CAPTCHA for repeated failures.",
                  "modelType": "STRIDE",
                  "new": false,
                  "score": ""
                },
                {
                  "id": "threat-0004",
                  "number": 4,
                  "title": "Notes Data in Transit — No HTTPS Enforcement",
                  "status": "Open",
                  "severity": "Medium",
                  "type": "Information disclosure",
                  "description": "The application does not enforce HTTPS. Login credentials and note contents are transmitted in cleartext, making them visible to anyone on the network path (e.g. a coffee-shop Wi-Fi attacker).",
                  "mitigation": "Deploy behind a TLS-terminating reverse proxy (nginx, Caddy). Send the Strict-Transport-Security (HSTS) header. Redirect all HTTP traffic to HTTPS.",
                  "modelType": "STRIDE",
                  "new": false,
                  "score": ""
                },
                {
                  "id": "threat-0005",
                  "number": 5,
                  "title": "Denial of Service — Unrestricted Request Volume",
                  "status": "Open",
                  "severity": "Medium",
                  "type": "Denial of service",
                  "description": "No rate limiting exists on any endpoint. An attacker can flood the API with requests, exhausting the Node.js event loop and making the application unavailable to legitimate users.",
                  "mitigation": "Apply global rate limiting with express-rate-limit. Set request body size limits (express.json({ limit: '10kb' })). Use a WAF or CDN-level DDoS protection in production.",
                  "modelType": "STRIDE",
                  "new": false,
                  "score": ""
                }
              ]
            }
