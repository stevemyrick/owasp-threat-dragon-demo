            "data": {
              "type": "tm.Process",
              "name": "Express API",
              "description": "Node.js/Express server. Handles registration, login, and CRUD notes endpoints.",
              "outOfScope": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "privilegeLevel": "",
              "threats": [
                {
                  "id": "threat-0002",
                  "number": 2,
                  "title": "IDOR on Note DELETE — Missing Ownership Check",
                  "status": "Open",
                  "severity": "High",
                  "type": "Tampering",
                  "description": "The DELETE /notes/:id endpoint removes the note matching :id without verifying that the requesting user owns it. Any authenticated user can delete any other user's notes by guessing or observing note IDs.",
                  "mitigation": "Add WHERE user_id = ? to the DELETE query and bind it to req.userId. Return 403 Forbidden if the note doesn't belong to the authenticated user.",
                  "modelType": "STRIDE",
                  "new": false,
                  "score": ""
                },
                {
                  "id": "threat-0006",
                  "number": 6,
                  "title": "Elevation of Privilege via IDOR",
                  "status": "Open",
                  "severity": "High",
                  "type": "Elevation of privilege",
                  "description": "Because note ownership is not validated, an authenticated low-privilege user can operate on data belonging to other users, effectively gaining access to resources beyond their authorisation scope.",
                  "mitigation": "Enforce user-scoped queries on all note operations. Validate req.userId === note.user_id before any modification. Log and alert on unexpected cross-user access patterns.",
                  "modelType": "STRIDE",
                  "new": false,
                  "score": ""
                }
              ]
            }
          },

